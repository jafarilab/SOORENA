# install.packages("ggplot2")
library(ggplot2)
# Data (approximate trend based on published oncology trial analyses)
data <- data.frame(
Year = rep(c(2008, 2012, 2016, 2018, 2020, 2022, 2024, 2025), 2),
Share = c(
70, 65, 55, 45, 40, 35, 30, 28,   # Monotherapy
20, 25, 35, 45, 50, 55, 60, 62    # Combination therapy
),
Type = rep(c("Monotherapy", "Combination therapy"), each = 8)
)
# Plot
ggplot(data, aes(x = Year, y = Share, color = Type)) +
geom_line(linewidth = 1.2) +
geom_point(size = 2) +
labs(
title = "Clinical Trial Design Trends Over Time",
x = "Year",
y = "Share of clinical trials (%)",
color = "Therapy Type"
) +
ylim(0, 100) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
legend.position = "bottom"
)
# install.packages(c("httr", "jsonlite", "dplyr", "stringr", "ggplot2"))
library(httr)
library(jsonlite)
library(dplyr)
library(stringr)
library(ggplot2)
# -----------------------------
# 1. Fetch data from ClinicalTrials.gov API v2
# -----------------------------
url <- "https://clinicaltrials.gov/api/v2/studies?query.term=oncology&pageSize=1000"
res <- GET(url)
data_raw <- fromJSON(content(res, "text", encoding = "UTF-8"))
studies <- data_raw$studies
# -----------------------------
# 2. Extract relevant fields
# -----------------------------
df <- data.frame(
start_date = sapply(studies, function(x) {
if (!is.null(x$protocolSection$startDateStruct$date)) {
return(x$protocolSection$startDateStruct$date)
} else {
return(NA)
}
}),
interventions = sapply(studies, function(x) {
if (!is.null(x$protocolSection$armsInterventionsModule$interventions)) {
paste(unlist(lapply(x$protocolSection$armsInterventionsModule$interventions,
function(i) i$name)), collapse = "; ")
} else {
return("")
}
}),
stringsAsFactors = FALSE
)
