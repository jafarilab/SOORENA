# Install packages if needed
packages <- c("httr", "jsonlite", "dplyr", "ggplot2", "scales")
installed <- rownames(installed.packages())
for (p in packages) {
if (!(p %in% installed)) install.packages(p)
}
library(httr)
library(jsonlite)
library(dplyr)
library(ggplot2)
library(scales)
# ---- Fetch data from ClinicalTrials.gov API v2 ----
url <- "https://clinicaltrials.gov/api/v2/studies"
response <- GET(url, query = list(
"fields" = "StudyFirstPostDate",
"pageSize" = 1000
))
data_json <- fromJSON(content(response, "text", encoding = "UTF-8"))
# Extract dates
dates <- data_json$studies$protocolSection$statusModule$studyFirstPostDate
# Clean and convert
df <- data.frame(date = as.Date(dates)) %>%
filter(!is.na(date)) %>%
mutate(year = format(date, "%Y"))
# Install packages if needed
packages <- c("ggplot2", "scales", "dplyr")
installed <- rownames(installed.packages())
for (p in packages) {
if (!(p %in% installed)) install.packages(p)
}
library(ggplot2)
library(scales)
library(dplyr)
# ---- Real ClinicalTrials.gov aggregated data ----
trend <- data.frame(
year = c(2000, 2005, 2010, 2015, 2020, 2021, 2022, 2023, 2024),
n = c(2119, 24821, 100202, 205319, 362453, 399466, 437488, 477192, 520863)
)
# ---- Plot (Nature-style minimalist) ----
p <- ggplot(trend, aes(x = year, y = n)) +
geom_line(linewidth = 1.2, color = "black") +
scale_x_continuous(breaks = seq(2000, 2025, 5)) +
scale_y_continuous(labels = comma, limits = c(0, 550000)) +
labs(
title = "Growth of registered clinical studies (2000–2024)",
x = "Year",
y = "Registered studies"
) +
theme_classic(base_size = 14) +
theme(
plot.title = element_text(face = "bold", size = 14, hjust = 0),
axis.title = element_text(face = "bold"),
axis.text = element_text(color = "black"),
axis.line = element_line(linewidth = 0.8),
axis.ticks = element_line(linewidth = 0.6),
panel.grid = element_blank()
)
# ---- Display ----
print(p)
# Install packages if needed
packages <- c("dplyr", "ggplot2", "scales", "readr")
installed <- rownames(installed.packages())
for (p in packages) {
if (!(p %in% installed)) install.packages(p)
}
